{% comment %}
  Renders top-level categories from the stiga-categorii menu as large cards on the /collections page.
  Each card links to the parent collection. Clicking through reveals subcategories via stiga-subcollections.
  The menu is the single source of truth — no handles or titles are hardcoded here.
{% endcomment %}

{% assign stiga_menu = linklists['stiga-categorii'] %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} stiga-hierarchy"
  style="padding-block-start: {{ section.settings.padding_top }}px; padding-block-end: {{ section.settings.padding_bottom }}px;"
>
  {% if section.settings.page_title != blank %}
    <h1 class="stiga-hierarchy__page-title">{{ section.settings.page_title }}</h1>
  {% endif %}

  <div class="stiga-hierarchy__grid">
    {% for top_link in stiga_menu.links %}
      <a href="{{ top_link.url }}" class="stiga-hierarchy__card">
        <span class="stiga-hierarchy__card-title">{{ top_link.title }}</span>
        <div class="stiga-hierarchy__card-image-wrap">
          {% if top_link.object.image %}
            {{
              top_link.object.image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                class: 'stiga-hierarchy__card-image',
                widths: '400, 600, 800',
                sizes: '(min-width: 750px) 50vw, 100vw'
            }}
          {% else %}
            <div class="stiga-hierarchy__card-image stiga-hierarchy__card-image--placeholder"></div>
          {% endif %}
        </div>
        {% if top_link.links.size > 0 %}
          <div class="stiga-hierarchy__card-subs">
            {% assign preview_count = 0 %}
            {% for sub in top_link.links %}
              {% if preview_count < 4 %}
                <span class="stiga-hierarchy__card-sub-name">{{ sub.title }}</span>
                {% assign preview_count = preview_count | plus: 1 %}
              {% endif %}
            {% endfor %}
            {% if top_link.links.size > 4 %}
              <span class="stiga-hierarchy__card-sub-more">+{{ top_link.links.size | minus: 4 }}</span>
            {% endif %}
          </div>
        {% endif %}
        <div class="stiga-hierarchy__card-footer">
          <span class="stiga-hierarchy__card-btn">{{ section.settings.button_label }}</span>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .stiga-hierarchy {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .stiga-hierarchy__page-title {
    font-size: 2rem;
    margin-block-end: 0;
  }

  .stiga-hierarchy__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--color-border, #e6e6e6);
  }

  .stiga-hierarchy__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border, #e6e6e6);
    padding: 24px 24px 28px;
    background: #fff;
    transition: box-shadow 0.2s ease;
  }

  .stiga-hierarchy__card:hover {
    box-shadow: inset 0 0 0 2px var(--color-border, #ccc);
  }

  .stiga-hierarchy__card-title {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin-block-end: 16px;
    text-align: center;
  }

  .stiga-hierarchy__card-image-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
  }

  .stiga-hierarchy__card-image {
    width: 100%;
    max-height: 320px;
    object-fit: contain;
    display: block;
  }

  .stiga-hierarchy__card-image--placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--color-border, #e6e6e6);
  }

  .stiga-hierarchy__card-subs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-block-start: 14px;
    justify-content: center;
  }

  .stiga-hierarchy__card-sub-name {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-foreground, #1a1a1a);
    opacity: 0.55;
    padding: 3px 9px;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 999px;
    white-space: nowrap;
    line-height: 1.4;
  }

  .stiga-hierarchy__card-sub-more {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary, #4a7c59);
    opacity: 0.8;
    padding: 3px 9px;
    border: 1px solid currentColor;
    border-radius: 999px;
    white-space: nowrap;
    line-height: 1.4;
  }

  .stiga-hierarchy__card-footer {
    margin-block-start: 24px;
  }

  .stiga-hierarchy__card-btn {
    display: inline-block;
    padding: 10px 28px;
    border: 2px solid var(--color-foreground, #1a1a1a);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground, #1a1a1a);
    background: transparent;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .stiga-hierarchy__card:hover .stiga-hierarchy__card-btn {
    background: var(--color-foreground, #1a1a1a);
    color: var(--color-background, #fff);
  }

  @media screen and (max-width: 749px) {
    .stiga-hierarchy__grid {
      grid-template-columns: 1fr;
    }

    .stiga-hierarchy__card-image-wrap {
      min-height: 160px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Stiga category hierarchy",
  "enabled_on": {
    "templates": ["list-collections"]
  },
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page title",
      "default": "Categorii"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "MAI MULT"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": []
}
{% endschema %}
