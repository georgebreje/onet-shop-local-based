{%- comment -%}
  Trust Bar — horizontal row of value propositions with icons.
  Used on the homepage and any other page to build customer confidence.
  Each block = one value prop (icon + headline + description).
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}

<div
  class="section-background color-{{ section.settings.color_scheme }}"
  style="padding-block-start: {{ section.settings.padding_top }}px; padding-block-end: {{ section.settings.padding_bottom }}px;"
></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} trust-bar"
  style="padding-block-start: {{ section.settings.padding_top }}px; padding-block-end: {{ section.settings.padding_bottom }}px;"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="trust-bar__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <ul class="trust-bar__list" role="list">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'value-prop' -%}
          <li class="trust-bar__item" {{ block.shopify_attributes }}>

            {%- if block.settings.icon != blank -%}
              <div class="trust-bar__icon-wrap">
                {{ block.settings.icon | image_url: width: 64 | image_tag: loading: 'lazy', class: 'trust-bar__icon-img', alt: block.settings.heading }}
              </div>
            {%- else -%}
              <div class="trust-bar__icon-wrap trust-bar__icon-wrap--svg" aria-hidden="true">
                {%- case block.settings.icon_name -%}
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                  {%- when 'leaf' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M17 8C8 10 5.9 16.17 3.82 19.34a1 1 0 0 0 1.36 1.4C7.7 18.94 13 17 17 8z"></path>
                      <path d="M3.41 18.41A16 16 0 0 0 8 21"></path>
                    </svg>
                  {%- when 'star' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                  {%- when 'refresh' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="23 4 23 10 17 10"></polyline>
                      <polyline points="1 20 1 14 7 14"></polyline>
                      <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                {%- endcase -%}
              </div>
            {%- endif -%}

            <div class="trust-bar__content">
              {%- if block.settings.heading != blank -%}
                <p class="trust-bar__title">{{ block.settings.heading }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="trust-bar__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </li>

      {%- endcase -%}
    {%- endfor -%}
  </ul>
</div>

{%- endif -%}


{% stylesheet %}

.trust-bar {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.trust-bar__heading {
  font-size: 1.125rem;
  font-weight: 700;
  text-align: center;
  margin: 0;
}

.trust-bar__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

@media screen and (min-width: 768px) {
  .trust-bar__list {
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
}

.trust-bar__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
  padding: 20px 12px;
}

.trust-bar__icon-wrap {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trust-bar__icon-wrap--svg {
  color: var(--color-primary, #4A7C59);
}

.trust-bar__icon-wrap--svg svg {
  width: 100%;
  height: 100%;
}

.trust-bar__icon-img {
  width: 44px;
  height: 44px;
  object-fit: contain;
}

.trust-bar__content {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.trust-bar__title {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-foreground-heading, #2B2B2B);
  margin: 0;
  line-height: 1.3;
}

.trust-bar__desc {
  font-size: 0.8125rem;
  color: var(--color-foreground, #6B6B6B);
  margin: 0;
  line-height: 1.5;
  opacity: 0.75;
}

{% endstylesheet %}


{% schema %}
{
  "name": "Trust bar",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "value-prop",
      "name": "Value proposition",
      "settings": [
        {
          "type": "select",
          "id": "icon_name",
          "label": "Icon",
          "options": [
            { "value": "truck",   "label": "Truck (Free shipping)" },
            { "value": "shield",  "label": "Shield (Warranty)" },
            { "value": "leaf",    "label": "Leaf (Eco / guides)" },
            { "value": "star",    "label": "Star (Reviews)" },
            { "value": "refresh", "label": "Refresh (Returns)" }
          ],
          "default": "truck"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon image",
          "info": "Optional — overrides the built-in SVG icon above. Recommended: 64×64px PNG."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On orders over 250 lei"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        {
          "type": "value-prop",
          "settings": {
            "icon_name": "truck",
            "heading": "Livrare gratuită",
            "description": "La comenzi peste 250 lei"
          }
        },
        {
          "type": "value-prop",
          "settings": {
            "icon_name": "shield",
            "heading": "Garanție extinsă",
            "description": "Pe toate uneltele manuale"
          }
        },
        {
          "type": "value-prop",
          "settings": {
            "icon_name": "leaf",
            "heading": "Ghiduri gratuite",
            "description": "Sfaturi de grădinărit expert"
          }
        },
        {
          "type": "value-prop",
          "settings": {
            "icon_name": "star",
            "heading": "Recenzii verificate",
            "description": "Mii de clienți mulțumiți"
          }
        }
      ]
    }
  ]
}
{% endschema %}
