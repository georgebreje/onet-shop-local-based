{%- comment -%}
  Trust Bar — horizontal row of value propositions.
  Editorial premium design: large decorative numbers, no icon circles.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}

<div
  class="section-background color-{{ section.settings.color_scheme }}"
  style="padding-block-start: {{ section.settings.padding_top }}px; padding-block-end: {{ section.settings.padding_bottom }}px;"
></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} trust-bar"
  style="padding-block-start: {{ section.settings.padding_top }}px; padding-block-end: {{ section.settings.padding_bottom }}px;"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="trust-bar__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <ul class="trust-bar__list" role="list">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'value-prop' -%}
          <li class="trust-bar__item" {{ block.shopify_attributes }}>

            {%- if block.settings.icon_svg != blank -%}
              <div class="trust-bar__custom-icon">
                <img src="{{ block.settings.icon_svg | asset_url }}" class="trust-bar__icon-img" alt="{{ block.settings.heading }}" loading="lazy" width="44" height="44">
              </div>
            {%- else -%}
              <span class="trust-bar__number" aria-hidden="true">{{ forloop.index | prepend: '0' }}</span>
            {%- endif -%}

            <div class="trust-bar__content">
              {%- if block.settings.heading != blank -%}
                <p class="trust-bar__title">{{ block.settings.heading }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="trust-bar__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </li>
      {%- endcase -%}
    {%- endfor -%}
  </ul>
</div>

{%- endif -%}


{% stylesheet %}

/* ── Section wrapper ── */
.trust-bar {
  display: flex;
  flex-direction: column;
  gap: 36px;
  border-block-start: 1px solid var(--color-border, #E0DBD4);
  border-block-end: 1px solid var(--color-border, #E0DBD4);
}

/* ── Heading ── */
.trust-bar__heading {
  font-size: clamp(1.125rem, 0.9rem + 0.7vw, 1.375rem);
  font-weight: 600;
  text-align: center;
  margin: 0;
  letter-spacing: -0.015em;
  color: var(--color-foreground-heading, #333333);
}

/* ── Item list ── */
.trust-bar__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
}

@media screen and (min-width: 768px) {
  .trust-bar__list {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* ── Individual item ── */
.trust-bar__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
  padding: 28px 24px;
  border-inline-end: 1px solid var(--color-border, #E0DBD4);
  transition: background 0.25s ease;
}

.trust-bar__item:last-child {
  border-inline-end: none;
}

/* mobile: remove right border on even items, add bottom border */
@media screen and (max-width: 767px) {
  .trust-bar__item {
    border-inline-end: 1px solid var(--color-border, #E0DBD4);
    border-block-end: 1px solid var(--color-border, #E0DBD4);
  }
  .trust-bar__item:nth-child(2n) {
    border-inline-end: none;
  }
  .trust-bar__item:nth-last-child(-n+2) {
    border-block-end: none;
  }
}

.trust-bar__item:hover {
  background: rgba(0,0,0,0.025);
}

/* ── Decorative number ── */
.trust-bar__number {
  font-size: 2.25rem;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--color-foreground-heading, #333333);
  opacity: 0.12;
  font-variant-numeric: tabular-nums;
  user-select: none;
}

/* ── Custom image icon ── */
.trust-bar__custom-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trust-bar__icon-img {
  width: 44px;
  height: 44px;
  object-fit: contain;
  opacity: 1;
}

/* ── Text ── */
.trust-bar__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.trust-bar__title {
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--color-foreground-heading, #333333);
  margin: 0;
  line-height: 1.3;
  letter-spacing: -0.01em;
}

.trust-bar__desc {
  font-size: 0.8125rem;
  color: var(--color-foreground, #333333);
  margin: 0;
  line-height: 1.6;
  opacity: 0.55;
}

{% endstylesheet %}


{% schema %}
