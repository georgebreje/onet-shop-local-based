{% comment %}
  Renders child collections for the current collection, sourced from the stiga-categorii menu.
  Only renders when the current collection has children in that menu.
  Do not hardcode handles — the menu is the single source of truth.
{% endcomment %}

{% assign stiga_menu = linklists['stiga-categorii'] %}
{% assign child_links = nil %}

{% for top_link in stiga_menu.links %}
  {% assign top_handle = top_link.url | split: '/collections/' | last | split: '?' | first | split: '/' | first %}
  {% if top_handle == collection.handle %}
    {% assign child_links = top_link.links %}
  {% else %}
    {% for child_link in top_link.links %}
      {% assign child_handle = child_link.url | split: '/collections/' | last | split: '?' | first | split: '/' | first %}
      {% if child_handle == collection.handle %}
        {% assign child_links = child_link.links %}
      {% endif %}
    {% endfor %}
  {% endif %}
{% endfor %}

{% if child_links.size > 0 %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="section section--page-width color-{{ section.settings.color_scheme }} stiga-subcollections">
    <div class="stiga-subcollections__grid">
      {% for child in child_links %}
        <a href="{{ child.url }}" class="stiga-subcollections__card">
          {% if child.object.image %}
            {{
              child.object.image
              | image_url: width: 400
              | image_tag:
                loading: 'lazy',
                class: 'stiga-subcollections__image',
                widths: '200, 400',
                sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw'
            }}
          {% else %}
            <div class="stiga-subcollections__image stiga-subcollections__image--placeholder"></div>
          {% endif %}
          <span class="stiga-subcollections__title">{{ child.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .stiga-subcollections {
    padding-block: 24px;
  }

  .stiga-subcollections__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media screen and (min-width: 750px) {
    .stiga-subcollections__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
  }

  @media screen and (min-width: 990px) {
    .stiga-subcollections__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stiga-subcollections__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: var(--card-corner-radius, 4px);
    overflow: hidden;
    border: 1px solid var(--color-border, #e6e6e6);
    transition: box-shadow 0.2s ease;
  }

  .stiga-subcollections__card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  }

  .stiga-subcollections__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .stiga-subcollections__image--placeholder {
    background-color: var(--color-border, #e6e6e6);
  }

  .stiga-subcollections__title {
    display: block;
    padding: 10px 12px 12px;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.3;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Subcategory grid",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-2"
    }
  ],
  "presets": []
}
{% endschema %}
