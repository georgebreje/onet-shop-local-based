{% comment %}
  stiga-catalog-megamenu.liquid

  Two-panel mega-menu for the Catalog nav item.
  Rendered inside .menu-list__submenu-inner.

  CSS loaded from assets/stiga-catalog-megamenu.css.
  Inline styles are used for all layout-critical properties so that
  any theme CSS that overrides display/flex/grid cannot break the layout.

  @param {object} stiga_menu  - linklists['stiga-categorii']
  @param {object} section     - section object
{% endcomment %}

{{ 'stiga-catalog-megamenu.css' | asset_url | stylesheet_tag }}

<div class="stiga-cmeg" id="stiga-cmeg">
  <div class="stiga-cmeg__body" style="display:flex;min-height:300px;max-height:calc(80vh - var(--header-height,60px));">

    {%- comment -%} ── Left: category list ── {%- endcomment -%}
    <ul class="stiga-cmeg__cats" aria-label="Categorii"
        style="list-style:none;margin:0;padding:12px 0;width:220px;flex-shrink:0;border-right:1px solid rgba(0,0,0,.08);overflow-y:auto;">
      {%- for link in stiga_menu.links -%}
        <li
          class="stiga-cmeg__cat{% if forloop.first %} is-active{% endif %}"
          data-cmeg-cat="{{ forloop.index0 }}"
        >
          <a
            class="stiga-cmeg__cat-link"
            href="{{ link.url }}"
            data-cmeg-trigger="{{ forloop.index0 }}"
            style="display:flex;align-items:center;justify-content:space-between;gap:8px;padding:10px 14px 10px 18px;text-decoration:none;border-left:3px solid transparent;"
          >
            <span>{{- link.title -}}</span>
            {%- if link.links.size > 0 -%}
              <svg class="stiga-cmeg__cat-arrow" width="5" height="9" viewBox="0 0 5 9"
                   fill="none" aria-hidden="true" style="flex-shrink:0;opacity:0.3;">
                <path d="M1 1l3 3.5L1 8" stroke="currentColor" stroke-width="1.4"
                      stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- endif -%}
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- comment -%} ── Right: sub-category panels ── {%- endcomment -%}
    <div class="stiga-cmeg__panels" style="flex:1;min-width:0;overflow-y:auto;padding:22px 28px 28px;">
      {%- for link in stiga_menu.links -%}

        {%- assign has_images = false -%}
        {%- for child in link.links -%}
          {%- if child.object.image -%}{%- assign has_images = true -%}{%- endif -%}
        {%- endfor -%}

        <div
          class="stiga-cmeg__panel{% if forloop.first %} is-active{% endif %}"
          data-cmeg-panel="{{ forloop.index0 }}"
          aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
          style="{% if forloop.first %}display:flex;flex-direction:column;gap:16px;{% else %}display:none;{% endif %}"
        >

          {%- if link.links.size > 0 -%}

            {%- if has_images -%}
              {%- comment -%} IMAGE LIST — photo left, name right {%- endcomment -%}
              <div class="stiga-cmeg__sub-grid"
                   style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px;">
                {%- for child in link.links -%}
                  <a class="stiga-cmeg__sub-card" href="{{ child.url }}"
                     style="display:flex;flex-direction:row;align-items:center;gap:12px;text-decoration:none;padding:6px 10px;border-radius:8px;border:1.5px solid transparent;">
                    <div class="stiga-cmeg__sub-img-wrap"
                         style="width:52px;height:52px;flex-shrink:0;border-radius:8px;overflow:hidden;background:#f4f6f4;display:flex;align-items:center;justify-content:center;">
                      {%- if child.object.image -%}
                        {{-
                          child.object.image
                          | image_url: width: 104
                          | image_tag:
                            loading: 'lazy',
                            class: 'stiga-cmeg__sub-img',
                            widths: '52, 104',
                            sizes: '52px'
                        -}}
                      {%- else -%}
                        <div class="stiga-cmeg__sub-img--empty"
                             style="width:55%;height:55%;background:#dde8e1;border-radius:6px;"></div>
                      {%- endif -%}
                    </div>
                    <span class="stiga-cmeg__sub-name"
                          style="flex:1;min-width:0;font-size:0.875rem;font-weight:500;text-align:left;line-height:1.35;word-break:break-word;">
                      {{- child.title -}}
                    </span>
                  </a>
                {%- endfor -%}
              </div>

            {%- else -%}
              {%- comment -%} TEXT LINK GRID (no images) {%- endcomment -%}
              <div class="stiga-cmeg__sub-grid-links"
                   style="display:grid;grid-template-columns:repeat(3,1fr);gap:4px 8px;width:100%;margin:0;padding:0;">
                {%- for child in link.links -%}
                  <div style="display:block;min-width:0;overflow:hidden;">
                    <a class="stiga-cmeg__sub-link" href="{{ child.url }}"
                       style="display:flex;align-items:center;gap:10px;width:100%;min-width:0;padding:9px 12px;text-decoration:none;border-radius:7px;box-sizing:border-box;">
                      <span class="stiga-cmeg__sub-link-dot"
                            style="flex-shrink:0;width:6px;height:6px;border-radius:50%;background:currentColor;opacity:0.25;"></span>
                      <span class="stiga-cmeg__sub-link-text"
                            style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        {{- child.title -}}
                      </span>
                      <svg class="stiga-cmeg__sub-link-arrow" width="14" height="14"
                           viewBox="0 0 14 14" fill="none" aria-hidden="true"
                           style="flex-shrink:0;opacity:0;transition:opacity .13s,transform .13s;">
                        <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.4"
                              stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}

          {%- endif -%}

          <a class="stiga-cmeg__all-link" href="{{ link.url }}"
             style="display:inline-flex;align-items:center;gap:6px;font-size:.8125rem;font-weight:700;text-decoration:none;align-self:flex-start;padding:7px 14px;border-radius:7px;">
            Toate {{ link.title | downcase }}
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
              <path d="M2 5.5h7M6.5 3l2.5 2.5L6.5 8"
                    stroke="currentColor" stroke-width="1.3"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<script type="module">
  (() => {
    const cmeg = document.getElementById('stiga-cmeg');
    if (!cmeg) return;

    const catLinks = cmeg.querySelectorAll('[data-cmeg-trigger]');
    const catItems = cmeg.querySelectorAll('[data-cmeg-cat]');
    const panels   = cmeg.querySelectorAll('[data-cmeg-panel]');

    function activate(idx) {
      catItems.forEach((el, i) => el.classList.toggle('is-active', i === idx));
      panels.forEach((el, i) => {
        const active = i === idx;
        el.classList.toggle('is-active', active);
        el.setAttribute('aria-hidden', active ? 'false' : 'true');
        /* Inline style guarantees visibility regardless of any theme CSS override */
        el.style.display = active ? 'flex' : 'none';
        if (active) {
          el.style.flexDirection = 'column';
          el.style.gap = '16px';
        }
      });
    }

    catLinks.forEach(link => {
      link.addEventListener('mouseenter', () =>
        activate(parseInt(link.dataset.cmegTrigger, 10))
      );
      link.addEventListener('keydown', e => {
        if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
        e.preventDefault();
        const idx  = parseInt(link.dataset.cmegTrigger, 10);
        const next = e.key === 'ArrowDown' ? idx + 1 : idx - 1;
        const target = cmeg.querySelector(`[data-cmeg-trigger="${next}"]`);
        if (target) { activate(next); target.focus(); }
      });
    });

    activate(0);
  })();
</script>
